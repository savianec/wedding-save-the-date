# Supabase — Project Settings → Data API (or legacy Project Settings → API)
# You need BOTH the project URL and a client-safe key.

# Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Use the publishable / anon public key ONLY (never the secret key here).
# This value is exposed to the browser — RLS must protect your tables.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Vercel (and other hosts): copy the same two variables into the dashboard
# (Project → Settings → Environment Variables). .env.local is not uploaded;
# you must set them there and trigger a new deployment for the live site.

# Optional: service role / secret key for server-only scripts (never NEXT_PUBLIC_*).
# SUPABASE_SERVICE_ROLE_KEY=
